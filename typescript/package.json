{
  "name": "apdev-js",
  "version": "0.2.0",
  "description": "Shared development tools for TypeScript/JavaScript projects - character validation, circular import detection, and more",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "apdev-js": "./dist/cli.js"
  },
  "files": [
    "dist",
    "release.sh",
    "src/charsets"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "format": "prettier --write src/ tests/",
    "apdev": "node dist/cli.js"
  },
  "keywords": [
    "development-tools",
    "character-validation",
    "circular-imports",
    "linting"
  ],
  "author": "aipartnerup <tercel.yi@gmail.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/aipartnerup/apdev",
    "directory": "typescript"
  },
  "homepage": "https://aipartnerup.com",
  "bugs": {
    "url": "https://github.com/aipartnerup/apdev/issues"
  },
  "dependencies": {
    "commander": "^13.0.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
